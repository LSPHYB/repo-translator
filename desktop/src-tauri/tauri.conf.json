{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Repo Translator",
  "version": "0.2.0",
  "identifier": "com.repotranslator.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Repo Translator",
        "width": 800,
        "height": 600,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/repo-translator-sidecar"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEwRkU0MTg0RkY0QzYxMEEKUldRS1lVei9oRUgrb0dKTldjYi9kQ2lWbzZGRFJFQytYUWc3TkdZaGlNamY2VkJXcFdFejhjTkMK",
      "endpoints": [
        "https://github.com/LSPHYB/repo-translator/releases/latest/download/latest.json"
      ]
    }
  }
}
