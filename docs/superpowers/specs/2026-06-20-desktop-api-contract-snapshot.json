  "x-ws-logs-contract": {
    "_comment": "Hand-documented because OpenAPI/Swagger has no schema coverage for WebSocket payloads. This route (WS /logs) is absent from the 'paths' object above for that reason -- FastAPI's openapi.json generation does not include @app.websocket routes at all. The shape below was read directly from repo_translator/api_server.py's _LogBroadcastHandler.emit method (captured 2026-06-20), not inferred or guessed.",
    "route": "WS /logs",
    "direction": "server -> client only (the handler never reads incoming client messages for data; the server's logs_ws coroutine does call websocket.receive_text() in a loop, but purely to detect WebSocketDisconnect -- it ignores whatever text the client sends)",
    "message_format": "One NDJSON (newline-delimited JSON) line per log record, sent as a WebSocket text frame via websocket.send_text(). Every logging.LogRecord emitted by the 'repo_translator' logger (and its children) while a client is connected is broadcast to every currently-connected client.",
    "fields": {
      "time": {
        "type": "string",
        "format": "ISO 8601 datetime, UTC, from datetime.now(timezone.utc).isoformat()",
        "example": "2026-06-20T14:32:01.123456+00:00"
      },
      "level": {
        "type": "string",
        "source": "record.levelname",
        "example": "INFO",
        "notes": "Standard Python logging level names: DEBUG, INFO, WARNING, ERROR, CRITICAL."
      },
      "logger": {
        "type": "string",
        "source": "record.name",
        "example": "repo_translator.sync"
      },
      "message": {
        "type": "string",
        "source": "record.getMessage()",
        "notes": "Already-formatted message (with %-style args substituted in); does not include exception tracebacks separately -- record.getMessage() only returns the log message text."
      }
    },
    "example_line": "{\"time\": \"2026-06-20T14:32:01.123456+00:00\", \"level\": \"INFO\", \"logger\": \"repo_translator.sync\", \"message\": \"Synced 3 files for repo 'example-repo'\"}",
    "source_reference": "repo_translator/api_server.py, class _LogBroadcastHandler, method emit (as of commit at time of this snapshot). Verify against current source if this file appears stale -- see Step 3 staleness note in docs/superpowers/plans/2026-06-20-desktop-frontend.md Task 0.5."
  }
}
